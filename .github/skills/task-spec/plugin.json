{
  "name": "task-spec",
  "version": "2.2.1",
  "description": "Generate atomic, vendor-portable, self-verifying Task-Spec v2.1 files for any agentic system. Works with Claude, Codex, Kimi, taskship, anthive, /goal, or manual execution.",
  "author": {
    "name": "Luan Moreno",
    "email": "luan.moreno@owshq.com"
  },
  "repository": "https://github.com/luanmorenommaciel/kurv-edp",
  "license": "MIT",
  "keywords": [
    "task-spec",
    "eval-driven-development",
    "edd",
    "agentic-tasks",
    "vendor-portable",
    "self-verifying"
  ],
  "entrypoints": {
    "generate": "scripts/generate-task-spec.sh",
    "validate": "scripts/validate-task-spec.sh",
    "gate": "scripts/safe-to-delegate.sh",
    "run": "scripts/run-task-spec.sh",
    "install": "scripts/install.sh"
  },
  "config": {
    "backlog_dir_env": "TASKSPEC_BACKLOG_DIR",
    "backlog_dir_default": "tasks",
    "version_source": "scripts/_lib.sh"
  }
}
